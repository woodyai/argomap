---
import Layout from '../layouts/Layout.astro';
import StarBackground from '../components/StarBackground';
import Navbar from '../components/Navbar';
import Globe from '../components/Globe';
import StatsCounter from '../components/StatsCounter';
import MemoriesPanel from '../components/MemoriesPanel';
import FloatingElements from '../components/FloatingElements';
---

<Layout title="ArgoMap — Explore Argo's Map">
  <main style="position: relative; height: 100vh; overflow: hidden; background: radial-gradient(ellipse at 50% 40%, #0d1b3e 0%, #070b1a 60%, #050816 100%);">
    <!-- Star Background -->
    <StarBackground client:load />

    <!-- Floating Decorations -->
    <FloatingElements client:load />

    <!-- Navbar -->
    <Navbar client:load />

    <!-- Subtle glow behind globe -->
    <div style="position: absolute; top: 50%; left: calc(50% - 150px); transform: translate(-50%, -50%); width: 550px; height: 550px; border-radius: 50%; background: radial-gradient(circle, rgba(59,130,246,0.08) 0%, rgba(59,130,246,0.03) 40%, transparent 70%); pointer-events: none; z-index: 5;"></div>

    <!-- Main Content -->
    <div style="position: relative; z-index: 10; display: flex; align-items: center; height: 100vh; padding-top: 56px;">
      <!-- Center Column - Globe and Title -->
      <div style="flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding-right: 320px; height: 100%; gap: 0;">
        <!-- Title -->
        <div style="text-align: center; position: relative; z-index: 20; flex-shrink: 0;">
          <h1 style="font-family: 'Nunito', sans-serif; font-size: 40px; font-weight: 900; letter-spacing: 5px; margin: 0; color: #ffffff; text-shadow: 0 0 60px rgba(59,130,246,0.25), 0 2px 10px rgba(0,0,0,0.5);">
            EXPLORE ARGO'S MAP
          </h1>
          <p style="font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 300; color: rgba(255,255,255,0.45); margin: 6px 0 0 0; letter-spacing: 3px;">
            A journey of growth and exploration
          </p>
        </div>

        <!-- Globe -->
        <div style="width: 480px; height: 480px; position: relative; flex-shrink: 0; margin: -8px 0;">
          <Globe client:only="react" />
        </div>

        <!-- Stats Counter -->
        <div style="position: relative; z-index: 20; flex-shrink: 0; margin-top: -16px;">
          <StatsCounter client:load />
        </div>
      </div>

      <!-- Right Panel - Memories -->
      <div style="position: fixed; right: 20px; top: 72px; bottom: 12px; z-index: 50; display: flex; align-items: flex-start;">
        <MemoriesPanel client:load />
      </div>
    </div>
  </main>
</Layout>
