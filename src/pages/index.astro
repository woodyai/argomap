---
import Layout from '../layouts/Layout.astro';
import StarBackground from '../components/StarBackground';
import Navbar from '../components/Navbar';
import FloatingElements from '../components/FloatingElements';
import MapExperience from '../components/MapExperience';
import { getCollection } from 'astro:content';

const citiesRaw = await getCollection('cities');
const cities = citiesRaw.map(c => ({
  id: c.id,
  ...c.data,
}));

const stats = {
  countries: new Set(cities.map(c => c.country)).size,
  cities: cities.length,
  locations: cities.reduce((sum, c) => sum + c.photos.length, 0),
};
---

<Layout title="ArgoMap — Explore Argo's Map">
  <main style="position: relative; min-height: 100vh; overflow-x: hidden; background: radial-gradient(ellipse at 50% 40%, #0d1b3e 0%, #070b1a 60%, #050816 100%);">
    <!-- Star Background -->
    <StarBackground client:load />

    <!-- Floating Decorations -->
    <FloatingElements client:load />

    <!-- Navbar -->
    <Navbar client:load />

    <!-- Subtle glow behind globe -->
    <div style="position: absolute; top: 50%; left: calc(50% - 150px); transform: translate(-50%, -50%); width: 550px; height: 550px; border-radius: 50%; background: radial-gradient(circle, rgba(59,130,246,0.08) 0%, rgba(59,130,246,0.03) 40%, transparent 70%); pointer-events: none; z-index: 5;"></div>

    <!-- SSR fallback: visible immediately, hidden once React hydrates -->
    <div id="ssr-fallback" style="position: relative; z-index: 10; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100vh; padding-top: 64px; text-align: center; gap: 24px;">
      <h1 style="font-family: 'Nunito', sans-serif; font-size: clamp(24px, 5vw, 40px); font-weight: 900; letter-spacing: 5px; margin: 0; color: #ffffff; text-shadow: 0 0 60px rgba(59,130,246,0.25), 0 2px 10px rgba(0,0,0,0.5);">
        EXPLORE ARGO'S MAP
      </h1>
      <p style="font-family: 'Inter', sans-serif; font-size: clamp(12px, 2vw, 14px); font-weight: 300; color: rgba(255,255,255,0.45); margin: 0; letter-spacing: 3px;">
        A journey of growth and exploration
      </p>
      <!-- Loading spinner -->
      <div style="margin-top: 32px;">
        <div style="width: 48px; height: 48px; border: 3px solid rgba(255,255,255,0.1); border-top-color: rgba(59,130,246,0.6); border-radius: 50%; animation: spin 1s linear infinite;"></div>
      </div>
      <p style="font-family: 'Nunito', sans-serif; font-size: 13px; color: rgba(255,255,255,0.3); margin: 0;">Loading globe...</p>
    </div>
    <style>
      @keyframes spin { to { transform: rotate(360deg); } }
    </style>

    <!-- Main Content — client:only renders nothing server-side, replaces fallback once loaded -->
    <MapExperience client:only="react" cities={cities} stats={stats} />

  </main>
</Layout>
