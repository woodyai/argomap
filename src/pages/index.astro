---
import Layout from '../layouts/Layout.astro';
import StarBackground from '../components/StarBackground';
import Navbar from '../components/Navbar';
import FloatingElements from '../components/FloatingElements';
import MapExperience from '../components/MapExperience';
import { getCollection } from 'astro:content';

const citiesRaw = await getCollection('cities');
const cities = citiesRaw.map(c => ({
  id: c.id,
  ...c.data,
}));

const stats = {
  countries: new Set(cities.map(c => c.country)).size,
  cities: cities.length,
  locations: cities.reduce((sum, c) => sum + c.photos.length, 0),
};
---

<Layout title="ArgoMap — Explore Argo's Map">
  <main style="position: relative; min-height: 100vh; overflow-x: hidden; background: radial-gradient(ellipse at 50% 40%, #0d1b3e 0%, #070b1a 60%, #050816 100%);">
    <!-- Star Background -->
    <StarBackground client:load />

    <!-- Floating Decorations -->
    <FloatingElements client:load />

    <!-- Navbar -->
    <Navbar client:load />

    <!-- Subtle glow behind globe -->
    <div style="position: absolute; top: 50%; left: calc(50% - 150px); transform: translate(-50%, -50%); width: 550px; height: 550px; border-radius: 50%; background: radial-gradient(circle, rgba(59,130,246,0.08) 0%, rgba(59,130,246,0.03) 40%, transparent 70%); pointer-events: none; z-index: 5;"></div>

    <!-- Main Content -->
    <MapExperience client:only="react" cities={cities} stats={stats} />
  </main>
</Layout>
