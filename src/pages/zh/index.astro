---
import Layout from '../../layouts/Layout.astro';
import StarBackground from '../../components/StarBackground';
import Navbar from '../../components/Navbar';
import MapExperience from '../../components/MapExperience';
import { getCollection } from 'astro:content';
import { strings } from '../../i18n/strings';

const citiesRaw = await getCollection('cities');
const cities = citiesRaw.map(c => ({
  id: c.id,
  ...c.data,
}));
const lang = 'zh';
const copy = strings[lang];

const stats = {
  countries: new Set(cities.map(c => c.country)).size,
  cities: cities.length,
  locations: cities.reduce((sum, c) => sum + c.photos.length, 0),
};
---

<Layout title={copy.pageTitle} lang={lang}>
  <main style="position: relative; min-height: 100vh; overflow-x: hidden; background: #070a14;">
    <StarBackground client:load />
    <Navbar client:load lang={lang} />

    <div id="ssr-fallback" style="position: relative; z-index: 10; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100vh; padding-top: 64px; text-align: center; gap: 18px;">
      <div style="font-family: 'Space Grotesk', system-ui, sans-serif; font-size: 9.5px; letter-spacing: 0.2em; text-transform: uppercase; color: #5b9fff; font-weight: 500; opacity: 0.85;">
        {copy.heroEyebrow}
      </div>
      <h1 style="font-family: 'Space Grotesk', 'Noto Sans SC', system-ui, sans-serif; font-size: clamp(24px, 4vw, 40px); font-weight: 300; letter-spacing: -0.045em; line-height: 1.08; margin: 0; color: rgba(228,235,255,0.93);">
        {copy.heroLineA}<br /><strong style="font-weight: 700;">{copy.heroLineB}</strong>
      </h1>
      <p style="font-family: 'Space Grotesk', 'Noto Sans SC', system-ui, sans-serif; font-size: 12.5px; color: rgba(155,178,225,0.72); margin: 0; max-width: 300px; line-height: 1.65;">
        {copy.heroLead}
      </p>
      <div id="ssr-fallback-spinner" style="margin-top: 32px;">
        <div style="width: 48px; height: 48px; border: 3px solid rgba(255,255,255,0.1); border-top-color: rgba(59,130,246,0.6); border-radius: 50%; animation: spin 1s linear infinite;"></div>
      </div>
      <p id="ssr-fallback-message" style="font-family: 'Nunito', sans-serif; font-size: 13px; color: rgba(255,255,255,0.3); margin: 0;">{copy.loading}</p>
      <button
        id="ssr-fallback-refresh"
        type="button"
        style="display: none; border: 1px solid rgba(255,255,255,0.18); background: rgba(255,255,255,0.06); color: #ffffff; padding: 10px 18px; border-radius: 999px; font-family: 'Inter', sans-serif; font-size: 13px; cursor: pointer;"
      >
        {copy.refresh}
      </button>
    </div>
    <style>
      @keyframes spin { to { transform: rotate(360deg); } }
    </style>
    <script is:inline define:vars={{ loadingSlowText: copy.loadingSlow }}>
      var fallback = document.getElementById('ssr-fallback');
      var spinner = document.getElementById('ssr-fallback-spinner');
      var message = document.getElementById('ssr-fallback-message');
      var refreshButton = document.getElementById('ssr-fallback-refresh');

      if (refreshButton) {
        refreshButton.addEventListener('click', function() { window.location.reload(); });
      }

      window.setTimeout(function() {
        if (!fallback || fallback.style.display === 'none') {
          return;
        }

        if (spinner) {
          spinner.style.display = 'none';
        }
        if (message) {
          message.textContent = loadingSlowText;
        }
        if (refreshButton) {
          refreshButton.style.display = 'inline-flex';
        }
      }, 15000);
    </script>

    <MapExperience client:only="react" cities={cities} stats={stats} lang={lang} initialCityId="hong-kong" />
  </main>
</Layout>
